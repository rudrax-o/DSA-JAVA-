package ifelse;

import java.util.Scanner;

//if number is divisible by 5
//if number is divisible by 3
//if number is divisible by 5 & 3 both
//if number is not divisible by 5 or 3
public class ifelseladder {
    public static void main(String[] args) {
        Scanner sc=new Scanner(System.in);
        int n =sc.nextInt();
        if(n%5==0 && n%3==0){
            System.out.println("Div by both 5 & 3");
        }
        else if(n%3==0){
            System.out.println("Div by 3");
        }
        else if(n%5==0){
            System.out.println("Div by 5");
        }
        else System.out.println("The number is not divisible by both 5 and 3");
    }
}
