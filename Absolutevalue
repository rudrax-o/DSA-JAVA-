import java.util.Scanner;

class AbsoluteValue {
    public static void main(String[] args) {
        try (Scanner sc = new Scanner(System.in)) {
            long n = sc.nextLong();

            if (n >= 0) {
                System.out.println(n);
            } else {
                System.out.println(-n);
            }
        }
    }
}
